FROM rust:1.87

RUN apt-get update && apt-get install -y libssl-dev pkg-config curl && rm -rf /var/lib/apt/lists/*

# Download the pre-built dioxus-cli binary directly from GitHub releases
RUN curl -L https://github.com/DioxusLabs/dioxus/releases/download/v0.6.3/dx-x86_64-unknown-linux-gnu-v0.6.3.tar.gz \
    | tar -xz -C /usr/local/bin

RUN rustup target add wasm32-unknown-unknown

WORKDIR /usr/src/app

EXPOSE 8080
EXPOSE 3001

CMD ["dx", "serve", "--port", "8080", "--addr", "0.0.0.0"]
